# ============================================================
# RADIX — Reglas de seguridad Apache
# ============================================================

# ── Bloquear acceso directo al archivo .env ───────────────
<Files ".env">
    Order allow,deny
    Deny from all
</Files>

# ── Bloquear acceso directo a config.php (solo debe usarse internamente) ──
<Files "config.php">
    Order allow,deny
    Deny from all
</Files>

# ── Bloquear archivos de debug/test/utilidades (nunca deben ser públicos) ──
<FilesMatch "^(reset_db|test_matrix|simulate_jump_c|simulate_phase0|simulate_reentry|recheck_progress|diagnose_board_progress|fix_db|debug_levels|mejorar_db_v2|invest_seed|debug_db|debug_user|fix_master_tron|limpiar_tesoreria|setup_webhook|limpiar_fundador|limpiar_pagos_duplicados|create_admin|db_setup)\.php$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Bloquear acceso directo a cleanup_test_users.php después de usarlo ──
<Files "cleanup_test_users.php">
    Order allow,deny
    Deny from all
</Files>

# ── Bloquear acceso web a la carpeta de migraciones ──────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^radix_api/migrations/ - [F,L]
</IfModule>
<IfModule !mod_rewrite.c>
    # Fallback si mod_rewrite no está disponible
    <FilesMatch "fix_master_tablero\.php$">
        Order allow,deny
        Deny from all
    </FilesMatch>
</IfModule>

# ── Bloquear carpeta database/ (contiene schema.sql con estructura completa de BD) ──
<IfModule mod_rewrite.c>
    RewriteRule ^database/ - [F,L]
</IfModule>

# ── Bloquear archivos de documentación/análisis internos ──
# Estos archivos revelan estructura interna, credenciales y análisis de vulnerabilidades
<FilesMatch "^(XAMPP_SETUP|README)\.(md|txt)$">
    Order allow,deny
    Deny from all
</FilesMatch>

<FilesMatch "^(analisis_mejoras_radix|reporte_final_radix|dashboard)\.html?$">
    Order allow,deny
    Deny from all
</FilesMatch>


# ── Evitar listado de directorios ─────────────────────────
Options -Indexes

# ── Forzar HTTPS ──────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# ── Cabeceras de seguridad HTTP ────────────────────────────
# Protegen contra XSS, clickjacking y sniffing de contenido
<IfModule mod_headers.c>
    # Evita que el navegador "adivine" el tipo MIME (previene ataques de content sniffing)
    Header always set X-Content-Type-Options "nosniff"
    # Bloquea que la app sea embebida en un iframe de otro dominio (anti-clickjacking)
    Header always set X-Frame-Options "DENY"
    # Activa el filtro XSS del navegador (protección adicional en browsers antiguos)
    Header always set X-XSS-Protection "1; mode=block"
    # No enviar la URL completa como Referer cuando se navega a otro dominio
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
